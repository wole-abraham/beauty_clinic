[Unit]
Description=Beauty Clinic FastAPI
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/beauty_clinic/backend
EnvironmentFile=/var/www/beauty_clinic/backend/.env
ExecStart=/var/www/beauty_clinic/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
